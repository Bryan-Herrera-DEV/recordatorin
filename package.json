{
  "name": "recordatorin",
  "private": true,
  "version": "1.0.0",
  "description": "Local-first notes and reminders app built with Electron, React, Tailwind and TypeScript.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "lint": "oxlint .",
    "preview": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc -b --pretty false",
    "version:major": "npm version major --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@uiw/react-md-editor": "^4.1.1",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "nanoid": "^5.1.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.9",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^7.3.6"
  },
  "build": {
    "appId": "com.recordatorin.desktop",
    "productName": "Recordatorin",
    "directories": {
      "output": "release"
    },
    "artifactName": "Recordatorin-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "overrides": {
    "lodash-es": "^4.18.1",
    "@excalidraw/excalidraw": {
      "nanoid": "^3.3.15"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "^3.3.15"
    }
  }
}
